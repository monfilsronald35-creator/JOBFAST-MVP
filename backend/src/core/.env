# ===============================
# 🚀 JOBFAST GLOBAL MVP
# ===============================

PORT=5000
NODE_ENV=development

APP_NAME=JOBFAST
APP_VERSION=2.2.0-MVP

API_PREFIX=/api

CLIENT_URL=http://localhost:3000

JSON_LIMIT=1mb

# ===============================
# 🌍 LOCATION ENGINE (MVP)
# ===============================

ENABLE_GPS=true
ENABLE_DISTANCE_SORT=true
ENABLE_CITY_NORMALIZATION=true

# ===============================
# 🔔 NOTIFICATIONS
# ===============================

ENABLE_NOTIFICATIONS=true

# ===============================
# 👷 CONSTRUCTION SYSTEM
# ===============================

ENABLE_CONSTRUCTION_MODULE=true

# ===============================
# 🚕 SERVICES ON DEMAND
# ===============================

ENABLE_SERVICES_MODULE=true

# ===============================
# 🏢 BUSINESS DIRECTORY
# ===============================

ENABLE_BUSINESS_DIRECTORY=true