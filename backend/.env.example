# ============================================================
# JOBFAST BACKEND — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Application
APP_NAME=JOBFAST
APP_VERSION=1.0.0
APP_STAGE=development          # development | staging | production

# Server
PORT=5000
API_PREFIX=/api/v1

# Security — CHANGE THESE BEFORE DEPLOYING TO PRODUCTION
JWT_SECRET=change-me-to-a-long-random-string-minimum-32-chars
ENCRYPTION_KEY=change-me-32-char-hex-key
BCRYPT_SALT_ROUNDS=12

# Database (MongoDB)
DB_URL=mongodb://localhost:27017/jobfast

# CORS — comma-separated origins or * for dev
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Admin Access — comma-separated admin emails
# Any user logging in with one of these emails receives the admin role.
ADMIN_EMAILS=admin@jobfast.com

# Feature Flags
FEATURE_MARKETPLACE=true
FEATURE_SERVICES=true

# Rate Limiting
RATE_LIMIT_MAX=100
MAX_RADIUS_KM=50

# Stripe — required for card payments (leave blank to disable Stripe in dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...