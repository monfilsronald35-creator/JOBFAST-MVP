# Wallet Service Configuration
NODE_ENV=development
PORT=3005

# Database
DATABASE_URL=postgresql://jobfast:password@localhost:5432/jobfast_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Country-specific Payment Methods (Haiti)
MONCASH_API_KEY=your_moncash_api_key
MONCASH_SECRET_KEY=your_moncash_secret_key
NATCASH_API_KEY=your_natcash_api_key
NATCASH_SECRET_KEY=your_natcash_secret_key

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
