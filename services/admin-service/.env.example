# Admin Service Configuration
NODE_ENV=development
PORT=3012

# Database
DATABASE_URL=postgresql://jobfast:password@localhost:5432/jobfast_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key

# Admin
ADMIN_EMAIL=admin@jobfast.com
ADMIN_PASSWORD=change_this_password

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
