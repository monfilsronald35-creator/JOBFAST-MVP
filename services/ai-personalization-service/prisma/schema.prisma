generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String
  lastName     String
  phone        String?
  role         String   @default("worker")
  bio          String?
  avatarUrl    String?
  isVerified   Boolean  @default(false)
  trustScore   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  professions UserProfession[]
  location    UserLocation?
}

model UserProfession {
  id           String   @id @default(cuid())
  userId       String
  professionId String
  experience   Int      @default(0)
  skills       String[]
  createdAt    DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profession  Profession @relation(fields: [professionId], references: [id])

  @@unique([userId, professionId])
}

model Profession {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String
  description String?
  createdAt   DateTime @default(now())

  userProfessions UserProfession[]
  jobs            Job[]
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String   @unique
  latitude  Float
  longitude Float
  city      String?
  state     String?
  country   String?
  address   String?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id          String   @id @default(cuid())
  title       String
  professionId String
  status      String   @default("active")
  city        String?
  state       String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profession Profession @relation(fields: [professionId], references: [id])
}
