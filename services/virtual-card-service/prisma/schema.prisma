generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VirtualCard {
  id                 String   @id @default(cuid())
  userId             String
  walletId           String
  cardType           String   @default("virtual")
  currency           String   @default("USD")
  last4              String
  maskedNumber       String
  stripeCardId       String   @unique
  stripeCardholderId String
  status             String   @default("active")
  isFrozen           Boolean  @default(false)
  dailyLimit         Float    @default(333.33)
  monthlyLimit       Float    @default(10000)
  transactionLimit   Float    @default(100)
  expiryMonth        Int
  expiryYear         Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet     Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transactions CardTransaction[]
}

model CardTransaction {
  id          String   @id @default(cuid())
  cardId      String
  amount      Float
  currency    String
  status      String
  merchant    String?
  description String?
  createdAt   DateTime @default(now())

  card VirtualCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  currency  String   @default("USD")
  isFrozen  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  virtualCards VirtualCard[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String
  lastName  String
  phone     String?
  role      String   @default("worker")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet       Wallet       @relation()
  virtualCards VirtualCard[]
}
