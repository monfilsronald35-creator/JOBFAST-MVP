# API Gateway Configuration
NODE_ENV=development
PORT=3000
API_GATEWAY_HOST=0.0.0.0

# Service URLs
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
JOB_SERVICE_URL=http://job-service:3003
BUSINESS_SERVICE_URL=http://business-service:3004
WALLET_SERVICE_URL=http://wallet-service:3005
CARD_SERVICE_URL=http://virtual-card-service:3006
NOTIFICATION_SERVICE_URL=http://notification-service:3007
AI_SERVICE_URL=http://ai-personalization-service:3008
FRAUD_SERVICE_URL=http://fraud-service:3009
SEARCH_SERVICE_URL=http://search-service:3010
ANALYTICS_SERVICE_URL=http://analytics-service:3011
ADMIN_SERVICE_URL=http://admin-service:3012

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
