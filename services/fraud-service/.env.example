# Fraud Service Configuration
NODE_ENV=development
PORT=3009

# Database
DATABASE_URL=postgresql://jobfast:password@localhost:5432/jobfast_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key

# Fraud Detection
FRAUD_THRESHOLD=0.7
DEVICE_FINGERING_ENABLED=true
DUPLICATE_ACCOUNT_CHECK=true

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
