// ===============================
// 🚀 JOBFAST CORE CONFIG
// ===============================

APP_NAME=JOBFAST
APP_ENV=development

# Backend API
API_URL=http://localhost:5000/api



// ===============================
// 🔐 AUTH SYSTEM (MVP)
// ===============================

JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d



// ===============================
// 🌍 LANGUAGE SYSTEM (NEW)
// ===============================

ENABLE_LANGUAGE=true
DEFAULT_LANGUAGE=ht

LANG_HT=true
LANG_FR=true
LANG_ES=true



// ===============================
// 🌍 LOCATION / GPS ENGINE (CORE)
// ===============================

DEFAULT_LAT=18.5601
DEFAULT_LNG=-68.3725
DEFAULT_RADIUS_KM=50

ENABLE_GPS=true
ENABLE_DISTANCE_SORT=true



// ===============================
// 🧱 CORE MODULES (SAFE MVP ONLY)
// ===============================

ENABLE_BUSINESS_DIRECTORY=true
ENABLE_CONSTRUCTION_MODE=true
ENABLE_ON_DEMAND_SERVICES=true



// ===============================
// 🏢 BUSINESS TYPES (DIRECTORY)
// ===============================

ENABLE_COMPANIES=true
ENABLE_RESTAURANTS=true
ENABLE_HOSPITALS=true
ENABLE_CLINICS=true
ENABLE_HOTELS=true
ENABLE_OFFICES=true
ENABLE_LAWYERS=true
ENABLE_MECHANICS=true
ENABLE_TOUR_GUIDES=true
ENABLE_ORGANIZATIONS=true



// ===============================
// 🚧 CONSTRUCTION SYSTEM CORE
// ===============================

ENABLE_CONSTRUCTION_ROLES=true
ENABLE_JOB_STATUS=true
ENABLE_AVAILABILITY_STATUS=true
ENABLE_WORK_BUSY_BUTTON=true

DEFAULT_ROLE=worker
ROLE_BOSS=true
ROLE_ASSISTANT=true
ROLE_WORKER=true



// ===============================
// 🧑 STATUS SYSTEM
// ===============================

STATUS_AVAILABLE=available
STATUS_BUSY=busy
STATUS_WORKING=working
STATUS_UNAVAILABLE=unavailable

DEFAULT_AVAILABILITY=available



// ===============================
// 📡 SERVICES ON DEMAND (MVP LIST)
// ===============================

ENABLE_SERVICES=true

SERVICE_CHEF=true
SERVICE_PLUMBER=true
SERVICE_DOCTOR=true
SERVICE_NURSE=true
SERVICE_TAXI=true
SERVICE_DELIVERY=true
SERVICE_CLEANING=true
SERVICE_VIDEOGRAPHER=true
SERVICE_DESIGNER=true



// ===============================
// 🔔 NOTIFICATIONS (MVP)
// ===============================

ENABLE_NOTIFICATIONS=true
NOTIFICATION_GLOBAL=true



// ===============================
// ⚡ PERFORMANCE SAFE MODE
// ===============================

ENABLE_DEBUG=false
ENABLE_ANALYTICS=false
ENABLE_REALTIME=false