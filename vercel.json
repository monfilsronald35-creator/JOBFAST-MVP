{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install --prefix apps/frontend && npm run build --prefix apps/frontend",
  "outputDirectory": "apps/frontend/dist",
  "installCommand": "npm install --prefix apps/frontend",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://jobfast-backend.onrender.com/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
