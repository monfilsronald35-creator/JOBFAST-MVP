{
  "buildCommand": "cd apps/frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "apps/frontend/dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://jobfast-backend.onrender.com/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
