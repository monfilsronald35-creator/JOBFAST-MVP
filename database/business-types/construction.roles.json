{
  "meta": {
    "version": "1.0.0",
    "domain": "construction",
    "description": "Standardized roles for construction workforce system"
  },

  "roles": [
    {
      "id": "boss",
      "label": "Boss / Contractor",
      "description": "Owner or main contractor who manages the entire construction project",
      "permissions": ["hire", "assign_tasks", "view_all_workers", "publish_jobs"]
    },

    {
      "id": "site_manager",
      "label": "Site Manager",
      "description": "Supervises daily construction site operations",
      "permissions": ["assign_tasks", "monitor_progress"]
    },

    {
      "id": "foreman",
      "label": "Foreman",
      "description": "Leads workers on-site and ensures work quality",
      "permissions": ["coordinate_workers", "report_progress"]
    },

    {
      "id": "assistant",
      "label": "Assistant / Helper",
      "description": "Supports skilled workers in daily tasks",
      "permissions": ["assist_tasks"]
    },

    {
      "id": "worker",
      "label": "General Worker",
      "description": "Basic labor worker on construction site",
      "permissions": ["execute_tasks"]
    },

    {
      "id": "engineer",
      "label": "Engineer",
      "description": "Handles structural and technical engineering work",
      "permissions": ["design_review", "technical_validation"]
    },

    {
      "id": "architect",
      "label": "Architect",
      "description": "Designs building plans and structures",
      "permissions": ["design", "approve_layouts"]
    },

    {
      "id": "electrician",
      "label": "Electrician",
      "description": "Handles electrical installations and wiring",
      "permissions": ["install_electrical_systems"]
    },

    {
      "id": "plumber",
      "label": "Plumber",
      "description": "Water and plumbing systems specialist",
      "permissions": ["install_plumbing"]
    },

    {
      "id": "mason",
      "label": "Mason",
      "description": "Bricklaying and concrete work specialist",
      "permissions": ["build_structures"]
    },

    {
      "id": "none",
      "label": "Not in Construction",
      "description": "User is not part of construction system",
      "permissions": []
    }
  ]
}