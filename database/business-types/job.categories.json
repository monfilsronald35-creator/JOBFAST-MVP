{
  "meta": {
    "version": "1.2.1",
    "domain": "global_job_marketplace",
    "description": "Unified construction + service + business + geo intelligence system",
    "mode": "production",
    "languageSupport": ["en", "fr", "ht"]
  },

  "businessCategories": [
    { "id": "company", "label": "Company", "type": "business" },
    { "id": "restaurant", "label": "Restaurant", "type": "business" },
    { "id": "hospital", "label": "Hospital", "type": "health" },
    { "id": "clinic", "label": "Clinic", "type": "health" },
    { "id": "hotel", "label": "Hotel", "type": "hospitality" },
    { "id": "office", "label": "Office", "type": "business" },
    { "id": "lawyer", "label": "Lawyer", "type": "legal", "mode": "both" },
    { "id": "mechanic", "label": "Mechanic", "type": "service" },
    { "id": "tour_guide", "label": "Tour Guide", "type": "tourism" },
    { "id": "organization", "label": "Organization", "type": "ngo" }
  ],

  "serviceJobs": {
    "flatList": [
      "chef","plumber","cleaning","delivery","taxi",
      "doctor","nurse","designer","videographer","lawyer",
      "electrician","mason","mechanic","driver",
      "security","firefighter","ambulance"
    ],

    "categories": [
      {
        "id": "on_demand",
        "jobs": ["chef", "plumber", "cleaning", "delivery", "taxi"]
      },
      {
        "id": "professional",
        "jobs": ["doctor", "nurse", "designer", "videographer", "lawyer"]
      },
      {
        "id": "field_work",
        "jobs": ["electrician", "mason", "mechanic", "driver"]
      },
      {
        "id": "emergency",
        "jobs": ["ambulance", "security", "fire_support"]
      }
    ]
  },

  "constructionJobs": {
    "enabled": true,
    "realTimeStatus": true,

    "roles": [
      {
        "id": "boss",
        "permissions": ["hire", "fire", "assign_tasks", "post_jobs", "view_all"],
        "canChangeAvailability": true
      },
      {
        "id": "site_manager",
        "permissions": ["manage_site", "assign_tasks"]
      },
      {
        "id": "foreman",
        "permissions": ["coordinate", "report"]
      },
      {
        "id": "assistant",
        "permissions": ["assist"]
      },
      {
        "id": "worker",
        "permissions": ["work"]
      },
      {
        "id": "engineer",
        "permissions": ["technical_review"]
      },
      {
        "id": "architect",
        "permissions": ["design"]
      },
      {
        "id": "electrician",
        "permissions": ["electrical"]
      },
      {
        "id": "plumber",
        "permissions": ["plumbing"]
      },
      {
        "id": "mason",
        "permissions": ["construction"]
      }
    ],

    "availabilitySystem": {
      "statuses": [
        { "id": "available", "default": true },
        { "id": "busy" },
        { "id": "offline" }
      ],
      "lastUpdated": true,
      "geoVisibility": true,
      "autoHideOffline": true
    }
  },

  "locationEngine": {
    "enabled": true,
    "features": [
      "gps",
      "distance_sorting",
      "map_clustering",
      "geo_nearby_search",
      "city_state_country_normalization"
    ],
    "settings": {
      "defaultRadiusKm": 5,
      "maxRadiusKm": 50,
      "precision": "high",
      "rankingBoost": "distance + activity"
    }
  },

  "notifications": {
    "enabled": true,

    "eventPriorityMap": {
      "new_job_posted": "high",
      "construction_hiring": "urgent",
      "worker_available": "normal",
      "service_request_created": "high"
    },

    "deliveryModes": ["push", "in_app", "sms"],
    "audienceTargeting": ["all", "nearby", "role_based", "category"],
    "broadcast": true
  },

  "searchSystem": {
    "enabled": true,
    "filters": [
      "category",
      "serviceType",
      "constructionRole",
      "availability",
      "distance"
    ],
    "sorting": ["nearest", "rating", "active", "newest"],
    "ranking": ["distance_weight", "activity_score", "verification"]
  },

  "profileSystem": {
    "requiredFields": [
      "name",
      "photo",
      "bio",
      "category",
      "serviceType",
      "constructionRole",
      "location",
      "availability",
      "rating",
      "verificationStatus",
      "isAvailable",
      "lastActive",
      "ratingCount"
    ],

    "optionalFields": [
      "portfolio",
      "skills",
      "languages",
      "experience_years"
    ]
  }
}