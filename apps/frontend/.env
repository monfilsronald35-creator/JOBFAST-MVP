
# ===============================
# 🚀 APP CORE CONFIG
# ===============================

VITE_APP_NAME=GlobalServiceApp
VITE_APP_ENV=development

# Backend API
VITE_API_URL=http://localhost:5000/api

# ===============================
# 🌍 LOCATION / GPS SYSTEM
# ===============================

VITE_DEFAULT_LAT=18.5601
VITE_DEFAULT_LNG=-68.3725
VITE_DEFAULT_ZOOM=10

VITE_ENABLE_GPS=true

# ===============================
# 🔔 NOTIFICATIONS SYSTEM
# ===============================

VITE_ENABLE_NOTIFICATIONS=true

# ===============================
# 🧱 CORE MODULES (MVP FEATURES)
# ===============================

VITE_ENABLE_CONSTRUCTION=true
VITE_ENABLE_ON_DEMAND_SERVICES=true
VITE_ENABLE_BUSINESS_DIRECTORY=true

# ===============================
# 👤 DEFAULT USER SETTINGS
# ===============================

VITE_DEFAULT_ROLE=user

# ===============================
# 🔍 SEARCH SYSTEM
# ===============================

VITE_MAX_SEARCH_RESULTS=20

# ===============================
# ⚡ PERFORMANCE / SAFETY
# ===============================

VITE_ENABLE_DEBUG=false
VITE_ENABLE_CONSOLE_LOGS=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_REALTIME=false