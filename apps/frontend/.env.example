# ============================================================
# JOBFAST FRONTEND — Environment Variables (Vite)
# Copy this file to .env and fill in your values.
# All variables MUST start with VITE_ to be accessible in the browser.
# NEVER commit .env to version control.
# ============================================================

# Backend API base URL (include /api/v1)
VITE_API_URL=http://localhost:5000/api/v1

# Alternative base URL used by services/api.js (without /api/v1 suffix)
VITE_API_BASE_URL=http://localhost:5000/api/v1