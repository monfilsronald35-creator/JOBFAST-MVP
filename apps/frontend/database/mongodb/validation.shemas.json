{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JOBFAST GLOBAL VALIDATION SCHEMAS",
  "description": "SAFE MVP VALIDATION SCHEMAS",
  "type": "object",

  "definitions": {

    "location": {
      "type": "object",
      "required": [
        "country",
        "state",
        "city"
      ],

      "properties": {

        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100
        },

        "state": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100
        },

        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100
        },

        "address": {
          "type": "string",
          "maxLength": 300
        },

        "zipCode": {
          "type": "string",
          "maxLength": 30
        },

        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },

        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },

        "distanceKm": {
          "type": "number",
          "minimum": 0
        },

        "locationCategory": {
          "type": "string",
          "enum": [
            "business",
            "construction",
            "restaurant",
            "hospital",
            "clinic",
            "hotel",
            "office",
            "lawyer",
            "mechanic",
            "tour_guide",
            "organization"
          ]
        }
      }
    },

    "business": {

      "type": "object",

      "required": [
        "name",
        "type",
        "ownerName",
        "location"
      ],

      "properties": {

        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 150
        },

        "type": {
          "type": "string",

          "enum": [
            "company",
            "restaurant",
            "hospital",
            "clinic",
            "hotel",
            "office",
            "lawyer",
            "mechanic",
            "tour_guide",
            "organization"
          ]
        },

        "ownerName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },

        "phone": {
          "type": "string",
          "maxLength": 30
        },

        "email": {
          "type": "string",
          "format": "email"
        },

        "description": {
          "type": "string",
          "maxLength": 3000
        },

        "bio": {
          "type": "string",
          "maxLength": 1000
        },

        "verified": {
          "type": "boolean"
        },

        "featured": {
          "type": "boolean"
        },

        "active": {
          "type": "boolean"
        },

        "location": {
          "$ref": "#/definitions/location"
        },

        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "constructionWorker": {

      "type": "object",

      "required": [
        "fullname",
        "role",
        "location"
      ],

      "properties": {

        "fullname": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },

        "role": {
          "type": "string",

          "enum": [
            "boss",
            "engineer",
            "architect",
            "foreman",
            "mason",
            "helper",
            "laborer",
            "electrician",
            "plumber",
            "welder",
            "painter",
            "tiler",
            "roofer",
            "carpenter",
            "steel_fixer",
            "machine_operator",
            "surveyor",
            "excavator_operator",
            "truck_driver",
            "site_manager",
            "finisher",
            "block_layer",
            "concrete_worker",
            "interior_designer",
            "construction_company",
            "terminador",
            "ajoudan",
            "feray",
            "kapent",
            "beton",
            "marble_worker"
          ]
        },

        "bio": {
          "type": "string",
          "maxLength": 1500
        },

        "availability": {
          "type": "string",

          "enum": [
            "available",
            "busy",
            "working",
            "unavailable"
          ]
        },

        "searchingJob": {
          "type": "boolean"
        },

        "workingNow": {
          "type": "boolean"
        },

        "skills": {
          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "phone": {
          "type": "string",
          "maxLength": 30
        },

        "whatsapp": {
          "type": "string",
          "maxLength": 30
        },

        "profileImage": {
          "type": "string"
        },

        "verified": {
          "type": "boolean"
        },

        "rating": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },

        "location": {
          "$ref": "#/definitions/location"
        },

        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "service": {

      "type": "object",

      "required": [
        "title",
        "serviceType",
        "providerName",
        "location"
      ],

      "properties": {

        "title": {
          "type": "string",
          "minLength": 2,
          "maxLength": 150
        },

        "serviceType": {
          "type": "string",

          "enum": [
            "chef",
            "plumber",
            "doctor",
            "nurse",
            "taxi",
            "delivery",
            "cleaning",
            "videographer",
            "designer",
            "mechanic",
            "electrician",
            "welder",
            "teacher",
            "developer",
            "photographer"
          ]
        },

        "providerName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },

        "bio": {
          "type": "string",
          "maxLength": 1500
        },

        "price": {
          "type": "number",
          "minimum": 0
        },

        "currency": {
          "type": "string",

          "enum": [
            "USD",
            "DOP",
            "HTG",
            "EUR"
          ]
        },

        "availability": {
          "type": "string",

          "enum": [
            "available",
            "busy",
            "working",
            "unavailable"
          ]
        },

        "phone": {
          "type": "string",
          "maxLength": 30
        },

        "whatsapp": {
          "type": "string",
          "maxLength": 30
        },

        "verified": {
          "type": "boolean"
        },

        "rating": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },

        "location": {
          "$ref": "#/definitions/location"
        },

        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "notification": {

      "type": "object",

      "required": [
        "title",
        "message",
        "type"
      ],

      "properties": {

        "title": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200
        },

        "message": {
          "type": "string",
          "maxLength": 2000
        },

        "type": {
          "type": "string",

          "enum": [
            "job",
            "business",
            "service",
            "construction",
            "system"
          ]
        },

        "targetUsers": {
          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "read": {
          "type": "boolean"
        },

        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}